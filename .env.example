# API key principal — usada por el servidor de la app (OCR, chat, etc.)
ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui

# API key separada del agente local de auditoría (scripts/agent-audit.js)
# Crea una segunda key en console.anthropic.com → Settings → API Keys
# Beneficio: ver costos del agente separados del costo de la app
# Si no la defines, el agente cae al ANTHROPIC_API_KEY de arriba
AUDIT_ANTHROPIC_API_KEY=sk-ant-tu-segunda-clave-aqui

# (Opcional) Cada cuántos minutos corre el agente en modo --watch
# AUDIT_INTERVAL_MIN=60
